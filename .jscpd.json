{
  "threshold": 0,
  "minLines": 5,
  "minTokens": 50,
  "reporters": ["console"],
  "absolute": true,
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/out/**",
    "**/coverage/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "pnpm-lock.yaml"
  ],
  "format": ["typescript", "javascript"],
  "exitCode": 1
}
